<Application x:Class="TangentInsightAgent.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <SolidColorBrush x:Key="Bg"     Color="#0B1220"/>
    <SolidColorBrush x:Key="Card"   Color="#111A2E"/>
    <SolidColorBrush x:Key="Accent" Color="#00AEEF"/>
    <SolidColorBrush x:Key="Fg"     Color="#E8EEF7"/>
    <SolidColorBrush x:Key="Muted"  Color="#7C8AA5"/>
  </Application.Resources>
</Application>
